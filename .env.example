# OurDAO frontend — Stellar / Soroban configuration
#
# Copy to .env.local and fill in. All values are optional; sensible testnet
# defaults are used when unset (except the contract id, which enables live data).

# Deployed OurDAO contract id (starts with C). Without it the UI runs in a
# read-only "not configured" state.
NEXT_PUBLIC_CONTRACT_ID=

# Soroban RPC endpoint (defaults to public testnet).
NEXT_PUBLIC_SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# Network passphrase (defaults to "Test SDF Network ; September 2015").
# For mainnet use: "Public Global Stellar Network ; September 2015"
NEXT_PUBLIC_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Optional: IPFS gateway for document metadata (Filecoin-analog content hashes).
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/
